<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>disable</ImplicitUsings>
    <AssemblyName>OpenLstGroundStation</AssemblyName>
    <RootNamespace>OpenLstGroundStation</RootNamespace>
    <ApplicationIcon>openlst_groundstation.ico</ApplicationIcon>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="System.IO.Ports" Version="10.0.5" />
    <Content Include="openlst_437_bootloader.hex">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="openlst_groundstation.ico" />
  </ItemGroup>
</Project>
